# Copy this file to .env.deploy and fill in the Hostinger FTP details.
# Keep .env.deploy private. It is ignored by Git.

FTP_PROTOCOL=ftp
FTP_HOST=145.79.4.134
FTP_PORT=21
FTP_USER=u748947752.Petro
# Optional: leave FTP_PASS empty to type the password safely when deploying.
FTP_PASS=
